<!--
  Use este arquivo se habilitar PublishTrimmed=true.
  Mantém os assemblies necessários para WPF e OpenCvSharp.
-->
<linker>
  <!-- WPF internals usados via reflexão -->
  <assembly fullname="PresentationFramework"  preserve="all"/>
  <assembly fullname="PresentationCore"       preserve="all"/>
  <assembly fullname="WindowsBase"            preserve="all"/>

  <!-- OpenCvSharp usa P/Invoke e reflexão interna -->
  <assembly fullname="OpenCvSharp"            preserve="all"/>
  <assembly fullname="OpenCvSharp.Extensions" preserve="all"/>

  <!-- Nossa aplicação -->
  <assembly fullname="ScreenActionTrigger.UI"          preserve="all"/>
  <assembly fullname="ScreenActionTrigger.Core"        preserve="all"/>
  <assembly fullname="ScreenActionTrigger.Vision"      preserve="all"/>
  <assembly fullname="ScreenActionTrigger.Input"       preserve="all"/>
  <assembly fullname="ScreenActionTrigger.Persistence" preserve="all"/>
  <assembly fullname="ScreenActionTrigger.Overlay"     preserve="all"/>
</linker>
