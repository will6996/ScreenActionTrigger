<UserControl x:Class="ScreenActionTrigger.UI.Views.RulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ScreenActionTrigger.Core.Models;assembly=ScreenActionTrigger.Core"
             Background="{StaticResource BgBaseBrush}"
             x:Name="ThisControl">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Rule list ═══ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="REGRAS" Style="{StaticResource SectionTitleStyle}"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="+ Nova Regra"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding AddRuleCommand}"
                        Margin="0,0,6,0"/>
                <CheckBox Content="Mostrar desabilitadas"
                          IsChecked="{Binding ShowDisabled}"
                          VerticalAlignment="Center"/>
            </StackPanel>

            <ListView Grid.Row="2"
                      Tag="{Binding}"
                      ItemsSource="{Binding FilteredRules}"
                      SelectedItem="{Binding SelectedRule}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}CD:{0}ms  Exec:{1}">
                                            <Binding Path="CooldownMs"/>
                                            <Binding Path="ExecutionCount"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <Ellipse Grid.Column="1" Width="8" Height="8"
                                     VerticalAlignment="Center" Margin="6,0,0,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill"
                                                Value="{StaticResource AccentErrorBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                <Setter Property="Fill"
                                                        Value="{StaticResource AccentSuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Duplicar"
                                  Command="{Binding PlacementTarget.Tag.DuplicateRuleCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Resetar contadores"
                                  Command="{Binding PlacementTarget.Tag.ResetRuleCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Ativar / Desativar"
                                  Command="{Binding PlacementTarget.Tag.ToggleRuleCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <Separator/>
                        <MenuItem Header="Remover"
                                  Foreground="{StaticResource AccentErrorBrush}"
                                  Command="{Binding PlacementTarget.Tag.RemoveRuleCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </ListView.ContextMenu>
            </ListView>

            <UniformGrid Grid.Row="3" Columns="3" Margin="0,8,0,0">
                <Button Content="Duplicar" Style="{StaticResource BaseButtonStyle}"
                        Command="{Binding DuplicateRuleCommand}"
                        CommandParameter="{Binding SelectedRule}" Margin="0,0,3,0"/>
                <Button Content="Resetar" Style="{StaticResource BaseButtonStyle}"
                        Command="{Binding ResetRuleCommand}"
                        CommandParameter="{Binding SelectedRule}" Margin="0,0,3,0"/>
                <Button Content="🗑" Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding RemoveRuleCommand}"
                        CommandParameter="{Binding SelectedRule}"/>
            </UniformGrid>
        </Grid>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"/>

        <!-- ═══ RIGHT: Rule editor ═══ -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="12,0,0,0">
                <!-- Placeholder when no rule selected -->
                <Border Background="{StaticResource BgCardBrush}"
                        CornerRadius="8" Padding="24"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedRule}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="← Selecione ou crie uma regra"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"/>
                </Border>

                <!-- Editor (visible when rule is selected) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedRule}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="EDITOR DE REGRA"
                               Style="{StaticResource SectionTitleStyle}"/>

                    <!-- Name -->
                    <TextBlock Text="Nome" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding SelectedRule.Name, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"/>

                    <!-- Region selector -->
                    <TextBlock Text="Região" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding AvailableRegions}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              SelectedValue="{Binding SelectedRule.RegionId}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="Nenhuma região — crie uma na aba Regiões primeiro."
                               Foreground="{StaticResource AccentWarningBrush}"
                               FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRegions}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Priority / Cooldown / MaxExec -->
                    <UniformGrid Columns="3" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="Prioridade" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedRule.Priority,
                                         UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="Cooldown (ms)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedRule.CooldownMs,
                                         UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Máx. exec. (-1=∞)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedRule.MaxExecutions,
                                         UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>

                    <CheckBox Content="Regra ativa"
                              IsChecked="{Binding SelectedRule.IsEnabled}"
                              Margin="0,0,0,12"/>

                    <Separator/>

                    <!-- ── CONDITION SECTION ── -->
                    <TextBlock Text="CONDIÇÃO" Style="{StaticResource SectionTitleStyle}"
                               Margin="0,8,0,6"/>

                    <ComboBox ItemsSource="{x:Static models:ConditionTypeValues.All}"
                              SelectedItem="{Binding SelectedRule.Condition.Type}"
                              Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Color Detection -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding SelectedRule.Condition.Type}"
                                        Value="{x:Static models:ConditionType.ColorDetection}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- Presets rápidos -->
                        <TextBlock Text="Cores rápidas" Style="{StaticResource LabelStyle}"/>
                        <ItemsControl ItemsSource="{Binding PresetColors}" Margin="0,0,0,8">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="28" Height="28" Margin="0,0,4,4"
                                            ToolTip="{Binding Name}"
                                            Command="{Binding DataContext.ApplyColorPresetCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="4"
                                                        Background="{Binding Hex, Converter={StaticResource ColorPreviewConverter}}"
                                                        BorderBrush="{StaticResource BgBorderBrush}"
                                                        BorderThickness="1"/>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <UniformGrid Columns="2" Margin="0,0,0,6">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Cor principal (#RRGGBB)"
                                           Style="{StaticResource LabelStyle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SelectedRule.Condition.TargetColor,
                                                  UpdateSourceTrigger=PropertyChanged}"/>
                                    <Border Grid.Column="1" Margin="4,1,0,1" CornerRadius="3"
                                            Background="{Binding SelectedRule.Condition.TargetColor,
                                                Converter={StaticResource ColorPreviewConverter}}"/>
                                    <Button Grid.Column="2" Content="🎯" Width="32" Margin="4,0,0,0"
                                            Style="{StaticResource BaseButtonStyle}"
                                            ToolTip="Capturar cor da tela"
                                            Command="{Binding PickColorFromScreenCommand}"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Tolerância (0–255)"
                                           Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding SelectedRule.Condition.ColorTolerance,
                                             UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- Cores adicionais -->
                        <TextBlock Text="Cores adicionais (qualquer uma satisfaz)"
                                   Style="{StaticResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox Width="90" Margin="0,0,4,0"
                                     Text="{Binding NewExtraColor, UpdateSourceTrigger=PropertyChanged}"/>
                            <Border Width="22" Height="22" Margin="0,0,4,0" CornerRadius="3"
                                    Background="{Binding NewExtraColor,
                                        Converter={StaticResource ColorPreviewConverter}}"/>
                            <Button Content="🎯" Width="32" Margin="0,0,4,0"
                                    Style="{StaticResource BaseButtonStyle}"
                                    ToolTip="Capturar cor da tela"
                                    Command="{Binding PickExtraColorFromScreenCommand}"/>
                            <Button Content="+ Adicionar" Style="{StaticResource BaseButtonStyle}"
                                    Command="{Binding AddExtraTargetColorCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ExtraColorError}"
                                   Foreground="{StaticResource AccentErrorBrush}"
                                   FontSize="11" Margin="0,0,0,6">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExtraColorError,
                                            Converter={StaticResource NotNullToBoolConverter}}"
                                                     Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding SelectedRule.Condition.TargetColors}"
                                      Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Width="18" Height="18" CornerRadius="3" Margin="0,0,6,0"
                                                Background="{Binding Converter={StaticResource ColorPreviewConverter}}"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Button Content="✕" Margin="8,0,0,0" Width="24" Height="24"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Command="{Binding DataContext.RemoveExtraTargetColorCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Mínimo de pixels (%)"
                                           Style="{StaticResource LabelStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Slider Width="120" Minimum="0" Maximum="1"
                                            Value="{Binding SelectedRule.Condition.MinColorPercentage}"
                                            IsSnapToTickEnabled="True" TickFrequency="0.01"/>
                                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                               Text="{Binding SelectedRule.Condition.MinColorPercentage,
                                                   StringFormat=P0}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Pixels mínimos (ícones pequenos)"
                                           Style="{StaticResource LabelStyle}"
                                           ToolTip="Se &gt; 0, ignora o % e dispara ao encontrar N pixels da cor"/>
                                <TextBox Text="{Binding SelectedRule.Condition.MinMatchingPixels,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Ex: 10 para baús/ícones pequenos. 0 = usar % acima."/>
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="Dica: para baús ou ícones pequenos, use Pixels mínimos = 10–50 e reduza o %."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    </StackPanel>

                    <!-- Change Detection -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding SelectedRule.Condition.Type}"
                                        Value="{x:Static models:ConditionType.ChangeDetection}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Mudança mínima (%)"
                                   Style="{StaticResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Slider Width="200" Minimum="0.01" Maximum="1"
                                    Value="{Binding SelectedRule.Condition.MinChangePercentage}"
                                    TickFrequency="0.05"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0"
                                       Text="{Binding SelectedRule.Condition.MinChangePercentage,
                                            StringFormat=P0}"/>
                        </StackPanel>
                        <TextBlock Text="Sensibilidade"
                                   Style="{StaticResource LabelStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider Width="200" Minimum="0.01" Maximum="1"
                                    Value="{Binding SelectedRule.Condition.ChangeSensitivity}"
                                    TickFrequency="0.05"/>
                            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0"
                                       Text="{Binding SelectedRule.Condition.ChangeSensitivity,
                                            StringFormat=P0}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Template Matching -->
                    <StackPanel Margin="0,0,0,10">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger
                                        Binding="{Binding SelectedRule.Condition.Type}"
                                        Value="{x:Static models:ConditionType.TemplateMatching}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Template" Style="{StaticResource LabelStyle}"/>
                    <ComboBox ItemsSource="{Binding AvailableTemplates}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedRule.Condition.TemplateId}"
                              Margin="0,0,0,4"/>
                        <CheckBox Content="Negar condição (NOT)"
                                  IsChecked="{Binding SelectedRule.Condition.IsNegated}"/>
                    </StackPanel>

                    <Separator/>

                    <!-- ── ACTIONS SECTION ── -->
                    <DockPanel Margin="0,8,0,6" LastChildFill="False">
                        <TextBlock Text="AÇÕES" Style="{StaticResource SectionTitleStyle}"
                                   DockPanel.Dock="Left" VerticalAlignment="Center"/>
                        <Button Content="+ Adicionar Ação"
                                Style="{StaticResource AccentButtonStyle}"
                                DockPanel.Dock="Right"
                                Command="{Binding AddActionToRuleCommand}"
                                CommandParameter="{Binding SelectedRule}"/>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding SelectedRule.Actions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BgBorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Tipo de ação"
                                                       Style="{StaticResource LabelStyle}"/>
                                            <ComboBox
                                                ItemsSource="{x:Static models:ActionTypeValues.All}"
                                                SelectedItem="{Binding Type}"
                                                Margin="0,0,0,6">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Converter={StaticResource EnumToStringConverter}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- Caminho gravado -->
                                            <StackPanel Margin="0,0,0,6">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}"
                                                                         Value="{x:Static models:ActionType.MouseFollowPath}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Style="{StaticResource LabelStyle}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="Caminho: {0} ponto(s)">
                                                            <Binding Path="PathPoints.Count"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <Button Content="⏺ Gravar caminho"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Margin="0,0,6,0"
                                                            Command="{Binding DataContext.RequestPathRecordingCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    <Button Content="Limpar"
                                                            Style="{StaticResource BaseButtonStyle}"
                                                            Command="{Binding DataContext.ClearPathCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                                <CheckBox Content="Clique esquerdo ao final do caminho"
                                                          IsChecked="{Binding PathLeftClickAtEnd}"
                                                          Margin="0,0,0,4"/>
                                                <TextBlock Text="Delay entre pontos (ms)"
                                                           Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding PathStepDelayMs,
                                                             UpdateSourceTrigger=PropertyChanged}"
                                                         Width="80" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                            <!-- Key field (keyboard actions) -->
                                            <TextBox
                                                Text="{Binding KeyCode,
                                                    UpdateSourceTrigger=PropertyChanged}"
                                                Tag="Tecla (ex: F, ENTER, SPACE, CTRL+A…)"
                                                Margin="0,0,0,4">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                Binding="{Binding Type}"
                                                                Value="{x:Static models:ActionType.KeyPress}">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger
                                                                Binding="{Binding Type}"
                                                                Value="{x:Static models:ActionType.KeyHold}">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger
                                                                Binding="{Binding Type}"
                                                                Value="{x:Static models:ActionType.KeyRelease}">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger
                                                                Binding="{Binding Type}"
                                                                Value="{x:Static models:ActionType.KeyCombination}">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <!-- Timing -->
                                            <UniformGrid Columns="3">
                                                <StackPanel Margin="0,0,4,0">
                                                    <TextBlock Text="Delay (ms)"
                                                               Style="{StaticResource LabelStyle}"/>
                                                    <TextBox Text="{Binding DelayBeforeMs,
                                                                 UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,4,0">
                                                    <TextBlock Text="Repetições"
                                                               Style="{StaticResource LabelStyle}"/>
                                                    <TextBox Text="{Binding RepeatCount,
                                                                 UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel>
                                                    <TextBlock Text="Delay rep. (ms)"
                                                               Style="{StaticResource LabelStyle}"/>
                                                    <TextBox Text="{Binding RepeatDelayMs,
                                                                 UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </UniformGrid>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="🗑"
                                                Width="30" Height="30"
                                                VerticalAlignment="Top"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Tag="{Binding DataContext,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                Command="{Binding DataContext.RemoveActionFromRuleCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <Button.CommandParameter>
                                                <MultiBinding Converter="{StaticResource RulePlusActionConverter}">
                                                    <Binding Path="DataContext.SelectedRule"
                                                             RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    <Binding/>
                                                </MultiBinding>
                                            </Button.CommandParameter>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
