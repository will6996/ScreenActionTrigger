<UserControl x:Class="ScreenActionTrigger.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBaseBrush}">
    <ScrollViewer>
        <StackPanel Margin="20" MaxWidth="560">
            <TextBlock Text="CONFIGURAÇÕES" Style="{StaticResource HeadingStyle}" Margin="0,0,0,20"/>

            <!-- Capture -->
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Captura e Performance" Style="{StaticResource SectionTitleStyle}"/>
                    <TextBlock Text="Intervalo de captura (ms)" Style="{StaticResource LabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Slider Minimum="16" Maximum="1000" Width="220"
                                Value="{Binding CaptureIntervalMs}" IsSnapToTickEnabled="True" TickFrequency="16"/>
                        <TextBlock Text="{Binding CaptureIntervalMs, StringFormat={}{0} ms}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Máximo de regiões paralelas" Style="{StaticResource LabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Slider Minimum="1" Maximum="20" Width="220"
                                Value="{Binding MaxParallelRegions}" IsSnapToTickEnabled="True" TickFrequency="1"/>
                        <TextBlock Text="{Binding MaxParallelRegions}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <CheckBox Content="Processar em escala de cinza (mais rápido)"
                              IsChecked="{Binding GrayscaleProcessing}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Overlay -->
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Overlay" Style="{StaticResource SectionTitleStyle}"/>
                    <CheckBox Content="Habilitar overlay transparente" IsChecked="{Binding OverlayEnabled}"/>
                </StackPanel>
            </Border>

            <!-- Logging -->
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Logs e Monitoramento" Style="{StaticResource SectionTitleStyle}"/>
                    <CheckBox Content="Registrar detecções" IsChecked="{Binding LogDetections}" Margin="0,0,0,6"/>
                    <CheckBox Content="Registrar ações executadas" IsChecked="{Binding LogActions}" Margin="0,0,0,6"/>
                    <TextBlock Text="Máximo de entradas no painel" Style="{StaticResource LabelStyle}" Margin="0,8,0,3"/>
                    <TextBox Text="{Binding MaxMonitoringEntries}" Width="120" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Hotkeys -->
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Atalhos Globais" Style="{StaticResource SectionTitleStyle}"/>
                    <UniformGrid Columns="2" Margin="0,0,0,6">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Iniciar / Parar" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding HotkeyStartStop, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Pausar / Continuar" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding HotkeyPause, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- App behavior -->
            <Border Background="{StaticResource BgCardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Comportamento" Style="{StaticResource SectionTitleStyle}"/>
                    <CheckBox Content="Iniciar minimizado" IsChecked="{Binding StartMinimized}" Margin="0,0,0,6"/>
                    <CheckBox Content="Minimizar para bandeja" IsChecked="{Binding MinimizeToTray}"/>
                </StackPanel>
            </Border>

            <Button Content="Restaurar Padrões" Style="{StaticResource BaseButtonStyle}"
                    Command="{Binding RestoreDefaultsCommand}" Width="180" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
