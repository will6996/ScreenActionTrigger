<UserControl x:Class="ScreenActionTrigger.UI.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBaseBrush}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Category sidebar -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CATEGORIAS" Style="{StaticResource SectionTitleStyle}"/>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Categories}"
                     SelectedItem="{Binding FilterCategory}"
                     Background="{StaticResource BgCardBrush}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentPrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                <Button Content="📷 Capturar da Tela"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding CaptureFromScreenCommand}"
                        Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                <Button Content="📥 Importar Arquivo"
                        Style="{StaticResource BaseButtonStyle}"
                        Command="{Binding ImportTemplateAsyncCommand}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"/>

        <!-- Template grid -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search bar -->
            <TextBox Grid.Row="0" Margin="0,0,0,10"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Tag="Pesquisar templates…"/>

            <!-- Template cards -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredTemplates}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="160" Height="190" Margin="6"
                                    Background="{StaticResource BgCardBrush}"
                                    BorderBrush="{StaticResource BgBorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected,
                                                RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="{StaticResource AccentPrimaryBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="110"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Image preview -->
                                    <Border Grid.Row="0" Background="{StaticResource BgElevatedBrush}"
                                            CornerRadius="8,8,0,0">
                                        <Image Source="{Binding ImagePath}" Stretch="Uniform"
                                               Margin="8" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <!-- Info -->
                                    <StackPanel Grid.Row="1" Margin="8,6,8,6">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="10"/>
                                        <TextBlock Foreground="{StaticResource AccentSuccessBrush}"
                                                   FontSize="10">
                                            <TextBlock.Text>
                                                <Binding Path="MinConfidence" StringFormat="Min: {0:P0}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
