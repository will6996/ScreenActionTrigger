<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:ScreenActionTrigger.UI.Converters">

    <conv:BoolToVisibilityConverter    x:Key="BoolToVisConverter"/>
    <conv:BoolToVisibilityConverter    x:Key="InverseBoolToVisConverter"
                                       TrueValue="Collapsed" FalseValue="Visible"/>
    <conv:InverseBoolConverter         x:Key="InverseBoolConverter"/>
    <conv:ColorPreviewConverter        x:Key="ColorPreviewConverter"/>
    <conv:ConfidenceToColorConverter   x:Key="ConfidenceToColorConverter"/>
    <conv:NotNullToBoolConverter       x:Key="NotNullToBoolConverter"/>
    <conv:PauseResumeConverter         x:Key="PauseResumeConverter"/>
    <conv:MonitoringStatusConverter    x:Key="MonitoringStatusConverter"/>
    <conv:ActionTypeToKeyVisConverter  x:Key="ActionTypeToKeyVisConverter"/>
    <conv:ActionTypeToPathVisConverter x:Key="ActionTypeToPathVisConverter"/>
    <conv:EnumToStringConverter        x:Key="EnumToStringConverter"/>
    <conv:RulePlusActionConverter       x:Key="RulePlusActionConverter"/>
    <conv:StepPlusActionConverter       x:Key="StepPlusActionConverter"/>
    <conv:ActionTypeToMouseVisConverter x:Key="ActionTypeToMouseVisConverter"/>
    <conv:RegionIdToNameConverter         x:Key="RegionIdToNameConverter"/>
    <conv:PanelChevronConverter           x:Key="PanelChevronConverter"/>
    <BooleanToVisibilityConverter       x:Key="StdBoolToVisConverter"/>
</ResourceDictionary>
