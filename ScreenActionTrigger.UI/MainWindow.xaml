<Window x:Class="ScreenActionTrigger.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ScreenActionTrigger.UI.Views"
        xmlns:conv="clr-namespace:ScreenActionTrigger.UI.Converters"
        Title="{Binding Title}" Height="720" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource BgDeepBrush}"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVisConverter"/>
        <conv:InverseBoolConverter         x:Key="InverseBoolConverter"/>
        <conv:ColorPreviewConverter        x:Key="ColorPreviewConverter"/>
        <conv:ConfidenceToColorConverter   x:Key="ConfidenceToColorConverter"/>
        <conv:PauseResumeConverter         x:Key="PauseResumeConverter"/>
        <conv:MonitoringStatusConverter    x:Key="MonitoringStatusConverter"/>
        <conv:NotNullToBoolConverter       x:Key="NotNullToBoolConverter"/>
        <conv:ActionTypeToKeyVisConverter  x:Key="ActionTypeToKeyVisConverter"/>
        <BooleanToVisibilityConverter      x:Key="StdBoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Grid.Row="0" Background="{StaticResource BgDeepBrush}"
                Height="42" MouseLeftButtonDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="14,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="22" Height="22" Margin="0,0,8,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FF00AAFF" Offset="0"/>
                                <GradientStop Color="#FF7B2FFF" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Screen Action Trigger"
                               Foreground="White" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Profile name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding Profile.Name, StringFormat='— {0}'}"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="8,0,0,0" FontSize="12"/>
                <!-- Window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="─" Style="{StaticResource GhostButtonStyle}"
                            Width="36" FontSize="14"
                            Click="MinimizeButton_Click"/>
                    <Button Content="□" Style="{StaticResource GhostButtonStyle}"
                            Width="36" FontSize="12"
                            Click="MaximizeButton_Click"/>
                    <Button Content="✕"
                            Width="36" FontSize="13"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentErrorBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main toolbar -->
        <Border Grid.Row="1" Background="{StaticResource BgBaseBrush}"
                BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="0,0,0,1"
                Padding="10,6">
            <DockPanel LastChildFill="False">
                <!-- File operations -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="Novo"   Style="{StaticResource BaseButtonStyle}" Margin="0,0,3,0"
                            Command="{Binding NewProfileCommand}"/>
                    <Button Content="Abrir"  Style="{StaticResource BaseButtonStyle}" Margin="0,0,3,0"
                            Command="{Binding OpenProfileCommand}"/>
                    <Button Content="Salvar" Style="{StaticResource BaseButtonStyle}" Margin="0,0,3,0"
                            Command="{Binding SaveProfileCommand}"/>
                    <Button Content="Salvar Como…" Style="{StaticResource BaseButtonStyle}" Margin="0,0,16,0"
                            Command="{Binding SaveProfileAsCommand}"/>

                    <Separator Width="1" Margin="0,3,16,3"/>

                    <!-- Monitoring controls -->
                    <Button Style="{StaticResource SuccessButtonStyle}" Margin="0,0,4,0"
                            Command="{Binding StartMonitoringCommand}"
                            IsEnabled="{Binding IsMonitoring, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶  " FontSize="11"/>
                            <TextBlock Text="Iniciar"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerButtonStyle}" Margin="0,0,4,0"
                            Command="{Binding StopMonitoringCommand}"
                            IsEnabled="{Binding IsMonitoring}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="■  " FontSize="11"/>
                            <TextBlock Text="Parar"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BaseButtonStyle}" Margin="0,0,16,0"
                            Command="{Binding TogglePauseCommand}"
                            IsEnabled="{Binding IsMonitoring}">
                        <TextBlock Text="{Binding IsPaused, Converter={StaticResource PauseResumeConverter}}"/>
                    </Button>
                </StackPanel>

                <!-- Right side -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Overlay" Style="{StaticResource BaseButtonStyle}" Margin="0,0,3,0"
                            Command="{Binding ToggleOverlayCommand}"/>
                    <!-- Update badge -->
                    <Border Margin="0,0,8,0"
                            Background="{StaticResource AccentWarningBrush}"
                            CornerRadius="4" Padding="8,4"
                            VerticalAlignment="Center"
                            Visibility="{Binding UpdateVM.UpdateAvailable,
                                Converter={StaticResource BoolToVisConverter}}">
                        <TextBlock Text="{Binding UpdateVM.LatestVersion,
                                       StringFormat='🔄 v{0} disponível'}"
                                   Foreground="#FF1A1A1A" FontWeight="Bold"
                                   FontSize="11"/>
                    </Border>

                    <!-- Status indicator -->
                    <Border Background="{StaticResource BgCardBrush}"
                            BorderBrush="{StaticResource BgBorderBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource AccentErrorBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMonitoring}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentSuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding IsMonitoring, Converter={StaticResource MonitoringStatusConverter}}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab content -->
        <TabControl Grid.Row="2"
                    Background="{StaticResource BgBaseBrush}"
                    BorderThickness="0">
            <TabItem Header="🗺  Regiões">
                <views:RegionsView DataContext="{Binding RegionsVM}"/>
            </TabItem>
            <TabItem Header="⚡  Regras">
                <views:RulesView DataContext="{Binding RulesVM}"/>
            </TabItem>
            <TabItem Header="🖼  Templates">
                <views:TemplatesView DataContext="{Binding TemplatesVM}"/>
            </TabItem>
            <TabItem Header="📊  Monitoramento">
                <views:MonitoringView DataContext="{Binding MonitoringVM}"/>
            </TabItem>
            <TabItem Header="⚙  Configurações">
                <views:SettingsView DataContext="{Binding SettingsVM}"/>
            </TabItem>
            <TabItem Header="🔄  Atualização">
                <views:UpdateView DataContext="{Binding UpdateVM}"/>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="{StaticResource BgDeepBrush}"
                BorderBrush="{StaticResource BgBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="10" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} regiões  •  {1} regras  •  {2} templates">
                            <Binding Path="RegionsVM.Regions.Count"/>
                            <Binding Path="RulesVM.Rules.Count"/>
                            <Binding Path="TemplatesVM.Templates.Count"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
